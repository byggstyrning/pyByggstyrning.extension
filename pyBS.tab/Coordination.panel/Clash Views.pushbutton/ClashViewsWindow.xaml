<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Create Category Clash Views" Width="720" Height="960" MinWidth="620" MinHeight="750"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBackgroundBrush}">
    <!-- Styles will be loaded programmatically -->
    <Grid Margin="15">
        <Grid.Resources>
            <!-- DisplayMemberPath does not resolve IronPython Reactive types; ItemTemplate uses Binding -->
            <DataTemplate x:Key="LinkModelComboItemTemplate">
                <TextBlock Text="{Binding DisplayName}"
                           Foreground="{DynamicResource TextBrush}"
                           TextTrimming="CharacterEllipsis"/>
            </DataTemplate>
        </Grid.Resources>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*" MinHeight="240"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="Create Category Clash Views" Style="{DynamicResource HeaderTextBlockStyle}" Margin="0,0,0,5"/>
            <TextBlock Text="Pick two or more model categories. Each unique pair is clash-detected (bounding-box pre-filter + geometry confirm) in the host model, then isolated 3D views are placed on a sheet, grouped by pair and sub-grouped by level."
                       Style="{DynamicResource BodyTextBlockStyle}"
                       Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
        </StackPanel>

        <!-- Views + sheet (compact) -->
        <GroupBox Grid.Row="1" Header="Views and sheet" Margin="0,0,0,10" Padding="0,4,0,8">
            <Grid Margin="10,4,10,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,6">
                    <TextBlock Text="Name prefix" Style="{DynamicResource LabelTextBlockStyle}" Margin="0,0,0,3" FontSize="11"/>
                    <TextBox x:Name="namePrefixTextBox" Style="{DynamicResource PlaceholderTextBoxStyle}"
                             Tag="Prefix..." Height="28" Text="Clash - "/>
                </StackPanel>
                <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,6">
                    <TextBlock Text="Sheet no. prefix" Style="{DynamicResource LabelTextBlockStyle}" Margin="0,0,0,3" FontSize="11"/>
                    <TextBox x:Name="sheetPrefixTextBox" Style="{DynamicResource PlaceholderTextBoxStyle}"
                             Tag="e.g. CV-" Height="28" Text="CV-"/>
                </StackPanel>
                <StackPanel Grid.Row="0" Grid.Column="4" Margin="0,0,0,6">
                    <TextBlock Text="Iteration (optional)" Style="{DynamicResource LabelTextBlockStyle}" Margin="0,0,0,3" FontSize="11"
                               ToolTip="Repeat runs: token (e.g. R2) for unique view names, sheet name, and sheet numbers. Invalid characters become dashes."/>
                    <TextBox x:Name="iterationTextBox" Style="{DynamicResource PlaceholderTextBoxStyle}"
                             Tag="e.g. R2, Issue-12" Height="28" ToolTip="Optional suffix for duplicate-free names on a second run."/>
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="5" Margin="0,0,0,4">
                    <TextBlock Text="Group by level" Style="{DynamicResource LabelTextBlockStyle}" Margin="0,0,0,3" FontSize="11"/>
                    <CheckBox x:Name="groupByLevelCheckBox" Content="One view per pair x level"
                              IsChecked="True" VerticalAlignment="Center" Height="28"
                              Style="{DynamicResource StandardCheckBoxStyle}"/>
                </StackPanel>

                <TextBlock Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="5"
                           TextWrapping="Wrap"
                           Text="3D views use scale 1:100, default 3D view type (first by name), 500 mm crop padding on the clash union box, and a section box. Optional iteration avoids duplicate names. Sheet: up to 20 viewports per row, gaps between pairs, no title block."
                           Style="{DynamicResource SecondaryTextBlockStyle}" FontSize="11" FontStyle="Italic" Margin="0,2,0,0"/>
            </Grid>
        </GroupBox>

        <!-- Host + link categories (side by side so link GroupBox header toggle stays visible) -->
        <Grid Grid.Row="2" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

        <!-- Host Categories -->
        <GroupBox Grid.Column="0" Header="Host categories" Margin="0,0,0,0">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Pick two or more categories. All unique pairs will be clash-checked."
                           Style="{DynamicResource SecondaryTextBlockStyle}" Margin="0,0,0,8" TextWrapping="Wrap"/>

                <TextBox Grid.Row="1" x:Name="categorySearchTextBox" Style="{DynamicResource PlaceholderTextBoxStyle}"
                         Tag="Search categories..." Height="28" Margin="0,0,0,8"
                         TextChanged="categorySearchTextBox_TextChanged"/>

                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,8">
                    <Button x:Name="categorySelectAllButton" Content="Select all" Width="88" Height="26" Margin="0,0,8,0"
                            Style="{DynamicResource StandardButtonStyle}" ToolTip="Include all categories"
                            Click="categorySelectAllButton_Click"/>
                    <Button x:Name="categoryDeselectAllButton" Content="Deselect all" Width="88" Height="26"
                            Style="{DynamicResource SecondaryButtonStyle}" ToolTip="Exclude all categories"
                            Click="categoryDeselectAllButton_Click"/>
                </StackPanel>

                <Border Grid.Row="3" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="3">
                    <ListBox x:Name="categoryListBox" Background="{DynamicResource ControlBackgroundBrush}"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <CheckBox Content="{Binding CategoryName}"
                                          IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          Checked="categoryFilterCheckBox_Changed" Unchecked="categoryFilterCheckBox_Changed"
                                          Style="{DynamicResource StandardCheckBoxStyle}" Margin="2,2"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>

                <TextBlock Grid.Row="4" x:Name="categorySelectionCountText" Margin="0,6,0,0"
                           Style="{DynamicResource SecondaryTextBlockStyle}" Text="0 of 0 categories selected (0 pairs)"/>
            </Grid>
        </GroupBox>

        <!-- Link Categories -->
        <GroupBox Grid.Column="2" Margin="0,0,0,0">
            <GroupBox.Header>
                <CheckBox x:Name="againstLinkToggle" Content="Against link model"
                          IsChecked="False"
                          Style="{DynamicResource ToggleSwitchStyle}"
                          VerticalAlignment="Center"
                          Checked="againstLinkToggle_Changed" Unchecked="againstLinkToggle_Changed"/>
            </GroupBox.Header>
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Link selector -->
                <StackPanel Grid.Row="0" Margin="0,0,0,8">
                    <TextBlock Text="Linked model" Style="{DynamicResource LabelTextBlockStyle}" Margin="0,0,0,3" FontSize="11"
                               IsEnabled="{Binding IsChecked, ElementName=againstLinkToggle}"/>
                    <ComboBox x:Name="linkSelectorComboBox" Height="28"
                              IsEnabled="{Binding IsChecked, ElementName=againstLinkToggle}"
                              ItemTemplate="{StaticResource LinkModelComboItemTemplate}"
                              SelectionChanged="linkSelectorComboBox_SelectionChanged"
                              Style="{DynamicResource StandardComboBoxStyle}"/>
                </StackPanel>

                <!-- Link category search + buttons -->
                <TextBox Grid.Row="1" x:Name="linkCategorySearchTextBox" Style="{DynamicResource PlaceholderTextBoxStyle}"
                         Tag="Search link categories..." Height="28" Margin="0,0,0,8"
                         IsEnabled="{Binding IsChecked, ElementName=againstLinkToggle}"
                         TextChanged="linkCategorySearchTextBox_TextChanged"/>

                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,8">
                    <Button x:Name="linkSelectAllButton" Content="Select all" Width="88" Height="26" Margin="0,0,8,0"
                            Style="{DynamicResource StandardButtonStyle}"
                            IsEnabled="{Binding IsChecked, ElementName=againstLinkToggle}"
                            Click="linkSelectAllButton_Click"/>
                    <Button x:Name="linkDeselectAllButton" Content="Deselect all" Width="88" Height="26"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            IsEnabled="{Binding IsChecked, ElementName=againstLinkToggle}"
                            Click="linkDeselectAllButton_Click"/>
                </StackPanel>

                <!-- Link category list -->
                <Border Grid.Row="3" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="3"
                        IsEnabled="{Binding IsChecked, ElementName=againstLinkToggle}">
                    <ListBox x:Name="linkCategoryListBox" Background="{DynamicResource ControlBackgroundBrush}"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <CheckBox Content="{Binding CategoryName}"
                                          IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          Checked="linkCategoryFilterCheckBox_Changed" Unchecked="linkCategoryFilterCheckBox_Changed"
                                          Style="{DynamicResource StandardCheckBoxStyle}" Margin="2,2"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>

                <TextBlock Grid.Row="4" x:Name="linkCategorySelectionCountText" Margin="0,6,0,0"
                           Style="{DynamicResource SecondaryTextBlockStyle}" Text="Select a link model above"/>
            </Grid>
        </GroupBox>
        </Grid>

        <!-- Status and Buttons -->
        <Border Grid.Row="3" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0"
                Background="{DynamicResource BackgroundLightBrush}" Margin="-15,10,-15,-15" Padding="15,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="statusText" Grid.Column="0" VerticalAlignment="Center"
                           Style="{DynamicResource StatusTextBlockStyle}"
                           Text="Ready to create clash views"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="createButton" Content="Create Clash Views" Width="160" Height="30" IsDefault="True"
                            Style="{DynamicResource StandardButtonStyle}" Margin="0,0,10,0"
                            Click="createButton_Click"/>
                    <Button x:Name="cancelButton" Content="Cancel" Width="100" Height="30" IsCancel="True"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Click="cancelButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
