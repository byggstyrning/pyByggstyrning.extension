<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Clash Views Created" Width="600" Height="520" MinWidth="500" MinHeight="400"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBackgroundBrush}">
    <!-- Styles will be loaded programmatically -->
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="Clash Detection Complete" Style="{DynamicResource HeaderTextBlockStyle}" Margin="0,0,0,8"/>
            <TextBlock x:Name="summaryHeaderText"
                       Text="Clash views have been created and placed on a sheet."
                       Style="{DynamicResource BodyTextBlockStyle}"
                       Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
        </StackPanel>

        <!-- Sheet Info -->
        <Border Grid.Row="1" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" 
                Background="{DynamicResource BackgroundLightBrush}" CornerRadius="4" Margin="0,0,0,15" Padding="15,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Sheet: " FontWeight="SemiBold" Margin="0,0,5,4"/>
                <TextBlock Grid.Row="0" Grid.Column="1" x:Name="sheetInfoText" Text="-" TextWrapping="Wrap"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Views created: " FontWeight="SemiBold" Margin="0,0,5,4"/>
                <TextBlock Grid.Row="1" Grid.Column="1" x:Name="viewsCountText" Text="-"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Total clashes: " FontWeight="SemiBold" Margin="0,0,5,0"/>
                <TextBlock Grid.Row="2" Grid.Column="1" x:Name="clashesCountText" Text="-"/>
            </Grid>
        </Border>

        <!-- Views List -->
        <GroupBox Grid.Row="2" Header="Created Views" Margin="0,0,0,10">
            <Grid Margin="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Each view shows isolated clashing elements grouped by category pair and level."
                           Style="{DynamicResource SecondaryTextBlockStyle}" Margin="0,0,0,8" TextWrapping="Wrap" FontSize="11"/>

                <Border Grid.Row="1" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="3">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel x:Name="viewsListPanel" Margin="8">
                            <!-- Views will be added here programmatically -->
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>
        </GroupBox>

        <!-- Annotation Toggle -->
        <Border Grid.Row="3" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,1"
                Background="{DynamicResource BackgroundLightBrush}" Margin="-20,0,-20,15" Padding="20,12">
            <StackPanel>
                <TextBlock Text="Visibility Options" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <CheckBox x:Name="annotationsToggle" Content="Show annotations (dimensions, text, tags, etc.)"
                          IsChecked="False"
                          Checked="AnnotationsToggle_Changed" Unchecked="AnnotationsToggle_Changed"
                          Style="{DynamicResource StandardCheckBoxStyle}"/>
                <TextBlock Text="Annotations are hidden by default to keep clash views clean. Toggle to show/hide all annotation categories."
                           Style="{DynamicResource SecondaryTextBlockStyle}" Margin="24,4,0,0" FontSize="11" FontStyle="Italic"/>
            </StackPanel>
        </Border>

        <!-- Explanation -->
        <StackPanel Grid.Row="4" Margin="0,0,0,15">
            <TextBlock Text="What you're seeing" FontWeight="SemiBold" Margin="0,0,0,6"/>
            <TextBlock TextWrapping="Wrap" Style="{DynamicResource BodyTextBlockStyle}" FontSize="12" LineHeight="18">
                <Run FontWeight="SemiBold" Foreground="#E74C3C">Red elements:</Run>
                <Run> First category (host model). Darker lines help distinguish edges.</Run>
                <LineBreak/>
                <Run FontWeight="SemiBold" Foreground="#27AE60">Green elements:</Run>
                <Run> Second category (link model in cross-doc mode).</Run>
                <LineBreak/>
                <Run>Only clashing element pairs are visible. All other elements are hidden to isolate the conflicts.</Run>
            </TextBlock>
        </StackPanel>

        <!-- Close Button -->
        <Button Grid.Row="4" x:Name="closeButton" Content="Close" Width="120" Height="32"
                HorizontalAlignment="Right" VerticalAlignment="Bottom"
                Style="{DynamicResource StandardButtonStyle}" IsDefault="True" IsCancel="True"
                Click="closeButton_Click"/>
    </Grid>
</Window>
