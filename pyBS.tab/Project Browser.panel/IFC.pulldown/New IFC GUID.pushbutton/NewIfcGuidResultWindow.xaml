<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="IFC GUID — Results"
        Width="520"
        Height="480"
        MinWidth="440"
        MinHeight="360"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False"
        Background="{DynamicResource WindowBackgroundBrush}">

    <!-- Styles loaded programmatically -->

    <Grid Margin="{DynamicResource GridMargin}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Summary"
                   Style="{DynamicResource HeaderTextBlockStyle}"
                   FontSize="16"/>

        <Grid Grid.Row="1" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Grid.Column="0"
                    Margin="0,0,6,6"
                    Padding="10"
                    Background="{DynamicResource BackgroundLightBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="3">
                <StackPanel>
                    <TextBlock Text="Updated"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="11"
                               Style="{DynamicResource DefaultTextBlockStyle}"/>
                    <TextBlock x:Name="updatedCountText"
                               Text="0"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="{DynamicResource SuccessBrush}"
                               Style="{DynamicResource DefaultTextBlockStyle}"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="0" Grid.Column="1"
                    Margin="6,0,0,6"
                    Padding="10"
                    Background="{DynamicResource BackgroundLightBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="3">
                <StackPanel>
                    <TextBlock Text="Skipped"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="11"
                               Style="{DynamicResource DefaultTextBlockStyle}"/>
                    <TextBlock x:Name="skippedCountText"
                               Text="0"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="{DynamicResource WarningBrush}"
                               Style="{DynamicResource DefaultTextBlockStyle}"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="1" Grid.Column="0"
                    Grid.ColumnSpan="2"
                    Padding="10"
                    Background="{DynamicResource BackgroundLightBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="3">
                <StackPanel>
                    <TextBlock Text="Failed"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="11"
                               Style="{DynamicResource DefaultTextBlockStyle}"/>
                    <TextBlock x:Name="failedCountText"
                               Text="0"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="{DynamicResource ErrorBrush}"
                               Style="{DynamicResource DefaultTextBlockStyle}"/>
                </StackPanel>
            </Border>
        </Grid>

        <GroupBox Grid.Row="2"
                  Header="Details"
                  Margin="0,12,0,0"
                  Foreground="{DynamicResource TextBrush}"
                  Style="{DynamicResource DefaultGroupBoxStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock x:Name="summaryLineText"
                           Grid.Row="0"
                           Style="{DynamicResource BodyTextBlockStyle}"
                           TextWrapping="Wrap"
                           Margin="4,0,4,8"
                           Foreground="{DynamicResource TextBrush}"/>
                <TextBox x:Name="detailsTextBox"
                         Grid.Row="1"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         FontFamily="Consolas"
                         FontSize="11"
                         Background="{DynamicResource ControlBackgroundBrush}"
                         Foreground="{DynamicResource TextBrush}"
                         BorderBrush="{DynamicResource BorderBrush}"/>
            </Grid>
        </GroupBox>

        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,14,0,0">
            <Button x:Name="closeButton"
                    Content="Close"
                    Width="100"
                    IsDefault="True"
                    Style="{DynamicResource StandardButtonStyle}"
                    Click="closeButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
