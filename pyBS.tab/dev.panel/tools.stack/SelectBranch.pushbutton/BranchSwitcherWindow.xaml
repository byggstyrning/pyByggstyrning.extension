<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select Branch"
        Width="480"
        Height="650"
        MinWidth="380"
        MinHeight="420"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False"
        Background="{DynamicResource WindowBackgroundBrush}">

    <!-- Styles will be loaded programmatically -->

    <Window.Resources>
        <!-- Pill / badge style shared by type label and "current" badge -->
        <Style x:Key="BranchTypeBadgeStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="7,1,7,2"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
        </Style>

        <Style x:Key="BranchTypeBadgeTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#000000"/>
        </Style>

        <!-- Row container style: card-like, reacts to hover & selection -->
        <Style x:Key="BranchItemContainerStyle" TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="Margin" Value="0,1,0,1"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="RowBorder"
                                Background="{DynamicResource ControlBackgroundBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="3"
                                Padding="0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="3"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border x:Name="AccentBar"
                                        Grid.Column="0"
                                        Background="Transparent"
                                        CornerRadius="3,0,0,3"/>
                                <ContentPresenter Grid.Column="1"
                                                  Margin="10,3,8,3"
                                                  VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RowBorder" Property="Background"
                                        Value="{DynamicResource BackgroundLighterBrush}"/>
                                <Setter TargetName="RowBorder" Property="BorderBrush"
                                        Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="RowBorder" Property="BorderBrush"
                                        Value="{DynamicResource AccentBrush}"/>
                                <Setter TargetName="RowBorder" Property="Background"
                                        Value="{DynamicResource BackgroundLightBrush}"/>
                                <Setter TargetName="AccentBar" Property="Background"
                                        Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header: title + current branch summary card -->
        <Border Grid.Row="0"
                Background="{DynamicResource BackgroundLightBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="4"
                Padding="12,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Vertical">
                    <TextBlock Text="Select Branch"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextBrush}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <TextBlock Text="On "
                                   FontSize="11"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   VerticalAlignment="Center"/>
                        <Border Background="{DynamicResource AccentBrush}"
                                CornerRadius="8"
                                Padding="7,1,7,2"
                                VerticalAlignment="Center">
                            <TextBlock x:Name="currentBranchBadge"
                                       Text="(unknown)"
                                       FontSize="10"
                                       FontWeight="Bold"
                                       Foreground="#000000"/>
                        </Border>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Vertical"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <TextBlock x:Name="branchCountText"
                               Text="0 branches"
                               FontSize="11"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Right"
                               Foreground="{DynamicResource TextBrush}"/>
                    <TextBlock Text="local + origin"
                               FontSize="10"
                               HorizontalAlignment="Right"
                               Foreground="{DynamicResource TextLightBrush}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Plain-language primer: what is a branch, for non-git users -->
        <Border Grid.Row="1"
                Background="{DynamicResource BackgroundLightBrush}"
                BorderBrush="{DynamicResource AccentBrush}"
                BorderThickness="3,0,0,0"
                CornerRadius="0,3,3,0"
                Padding="10,6,10,6"
                Margin="0,8,0,0">
            <StackPanel>
                <TextBlock Text="What is a branch?"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextBrush}"/>
                <TextBlock FontSize="11"
                           Margin="0,2,0,0"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource TextSecondaryBrush}">
                    A branch is a different version of this toolbar. Pick one, hit Switch, and pyRevit reloads with those tools.
                    <LineBreak/>
                    <Run FontWeight="SemiBold" Text="master"/> = stable. Others = work in progress or experiments.
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- Status / hint line (shown only when there is something to say) -->
        <TextBlock x:Name="statusText"
                   Grid.Row="2"
                   Text=""
                   FontSize="11"
                   Margin="2,8,2,0"
                   TextWrapping="Wrap"
                   Visibility="Collapsed"
                   Foreground="{DynamicResource TextSecondaryBrush}"/>

        <!-- Search box -->
        <TextBox x:Name="searchBox"
                 Grid.Row="3"
                 Style="{DynamicResource PlaceholderTextBoxStyle}"
                 Tag="Filter branches..."
                 Margin="0,8,0,8"
                 TextChanged="SearchBox_TextChanged"/>

        <!-- Branch list -->
        <Border Grid.Row="4"
                Background="{DynamicResource ControlBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="4">
            <ListBox x:Name="branchList"
                     BorderThickness="0"
                     Background="Transparent"
                     Padding="6,6,6,6"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     HorizontalContentAlignment="Stretch"
                     ItemContainerStyle="{StaticResource BranchItemContainerStyle}"
                     SelectionChanged="BranchList_SelectionChanged"
                     MouseDoubleClick="BranchList_MouseDoubleClick"
                     KeyDown="BranchList_KeyDown">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid VerticalAlignment="Center" Height="22">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Colored dot indicating branch type -->
                            <Ellipse Grid.Column="0"
                                     Width="8" Height="8"
                                     Fill="{Binding type_color}"
                                     VerticalAlignment="Center"
                                     HorizontalAlignment="Left"/>

                            <!-- Branch name (single line) -->
                            <TextBlock Grid.Column="1"
                                       Text="{Binding name}"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Margin="8,0,8,0"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"
                                       Foreground="{DynamicResource TextBrush}"/>

                            <!-- LOCAL-only pill (branch not yet on origin) -->
                            <Border Grid.Column="2"
                                    Style="{StaticResource BranchTypeBadgeStyle}"
                                    Background="#90A4AE"
                                    Margin="0,0,4,0"
                                    Visibility="{Binding local_only_visibility}">
                                <TextBlock Text="LOCAL"
                                           Style="{StaticResource BranchTypeBadgeTextStyle}"/>
                            </Border>

                            <!-- REMOTE-only pill (not checked out locally yet) -->
                            <Border Grid.Column="3"
                                    Style="{StaticResource BranchTypeBadgeStyle}"
                                    Background="#B0BEC5"
                                    Margin="0,0,4,0"
                                    Visibility="{Binding remote_only_visibility}">
                                <TextBlock Text="REMOTE"
                                           Style="{StaticResource BranchTypeBadgeTextStyle}"/>
                            </Border>

                            <!-- Type label pill -->
                            <Border Grid.Column="4"
                                    Style="{StaticResource BranchTypeBadgeStyle}"
                                    Background="{Binding type_color}"
                                    Margin="0,0,4,0">
                                <TextBlock Text="{Binding type_label}"
                                           Style="{StaticResource BranchTypeBadgeTextStyle}"/>
                            </Border>

                            <!-- "Current" badge, visible only for active branch -->
                            <Border Grid.Column="5"
                                    Style="{StaticResource BranchTypeBadgeStyle}"
                                    Background="{DynamicResource SuccessBrush}"
                                    Visibility="{Binding current_visibility}">
                                <TextBlock Text="CURRENT"
                                           Style="{StaticResource BranchTypeBadgeTextStyle}"/>
                            </Border>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <!-- Hint row -->
        <TextBlock Grid.Row="5"
                   Text="Tip: double-click a branch to switch, or press Enter."
                   FontSize="10"
                   Margin="2,8,2,0"
                   Foreground="{DynamicResource TextLightBrush}"/>

        <!-- Footer buttons -->
        <StackPanel Grid.Row="6"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,10,0,0">
            <Button x:Name="cancelButton"
                    Content="Cancel"
                    Style="{DynamicResource SecondaryButtonStyle}"
                    MinWidth="90"
                    IsCancel="True"
                    Click="CancelButton_Click"/>
            <Button x:Name="switchReloadButton"
                    Content="Switch &amp; reload"
                    Style="{DynamicResource SuccessButtonStyle}"
                    MinWidth="130"
                    IsDefault="True"
                    Click="SwitchReloadButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
