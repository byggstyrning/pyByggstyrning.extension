<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="New IFC GUID"
        Width="460"
        Height="360"
        MinWidth="400"
        MinHeight="320"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False"
        Background="{DynamicResource WindowBackgroundBrush}">

    <!-- Styles loaded programmatically -->

    <Grid Margin="{DynamicResource GridMargin}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="New IFC GUID"
                       Style="{DynamicResource HeaderTextBlockStyle}"
                       FontSize="16"/>
            <TextBlock Text="Assign new IfcGUID values before IFC export (e.g. duplicated or split models)."
                       Style="{DynamicResource BodyTextBlockStyle}"
                       TextWrapping="Wrap"
                       Margin="0,6,0,0"/>
        </StackPanel>

        <GroupBox Grid.Row="1"
                  Header="Scope"
                  Margin="0,14,0,0"
                  Foreground="{DynamicResource TextBrush}">
            <StackPanel Margin="4,8,4,4">
                <RadioButton x:Name="selectionModeRadio"
                             Content="Current selection (instances only)"
                             IsChecked="True"
                             Margin="0,0,0,8"
                             Foreground="{DynamicResource TextBrush}"/>
                <RadioButton x:Name="wholeModelModeRadio"
                             Content="Whole model (instances and types)"
                             Foreground="{DynamicResource TextBrush}"/>
            </StackPanel>
        </GroupBox>

        <Border Grid.Row="2"
                Margin="0,12,0,0"
                Padding="10"
                Background="{DynamicResource BackgroundLightBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="3">
            <StackPanel>
                <TextBlock Text="IFC export tip"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextBrush}"
                           Margin="0,0,0,6"/>
                <TextBlock TextWrapping="Wrap"
                           Style="{DynamicResource BodyTextBlockStyle}"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           Text="Enable storing / using IfcGUID from element parameters in your IFC export setup so rewritten values are used as GlobalId on export."/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button x:Name="generateButton"
                    Content="Generate"
                    Width="110"
                    IsDefault="True"
                    Style="{DynamicResource StandardButtonStyle}"
                    Click="generateButton_Click"/>
            <Button x:Name="cancelButton"
                    Content="Cancel"
                    Width="100"
                    Margin="8,0,0,0"
                    IsCancel="True"
                    Style="{DynamicResource SecondaryButtonStyle}"
                    Click="cancelButton_Click"/>
        </StackPanel>

        <Border x:Name="busyOverlay"
                Grid.RowSpan="4"
                Style="{DynamicResource BusyOverlayStyle}">
            <Border Background="{DynamicResource WindowBackgroundBrush}"
                    CornerRadius="5"
                    Padding="24"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center">
                <StackPanel MinWidth="280">
                    <ProgressBar x:Name="progressBar"
                                 Height="22"
                                 Minimum="0"
                                 Maximum="100"
                                 Value="0"
                                 Margin="0,0,0,10"/>
                    <TextBlock x:Name="progressTextBlock"
                               Text="Preparing..."
                               HorizontalAlignment="Center"
                               Foreground="{DynamicResource TextBrush}"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</Window>
