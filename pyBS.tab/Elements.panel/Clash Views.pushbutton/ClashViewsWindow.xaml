<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Create Clash Views" Width="760" Height="760" MinWidth="640" MinHeight="560"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBackgroundBrush}">
    <!-- Styles will be loaded programmatically -->
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*" MinHeight="260"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="Create Clash Views" Style="{DynamicResource HeaderTextBlockStyle}" Margin="0,0,0,5"/>
            <TextBlock Text="Select categories. Every unordered category pair is clashed. One isolated 3D view is created per pair that has clashes, then placed on a sheet in a grid."
                       Style="{DynamicResource BodyTextBlockStyle}"
                       Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
        </StackPanel>

        <!-- Views + sheet options -->
        <GroupBox Grid.Row="1" Header="Views and sheet" Margin="0,0,0,10" Padding="0,4,0,8">
            <Grid Margin="10,4,10,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,6">
                    <TextBlock Text="View scale" Style="{DynamicResource LabelTextBlockStyle}" Margin="0,0,0,3" FontSize="11"/>
                    <ComboBox x:Name="scaleComboBox" Style="{DynamicResource StandardComboBoxStyle}" Height="28"/>
                </StackPanel>
                <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,6">
                    <TextBlock Text="3D view template" Style="{DynamicResource LabelTextBlockStyle}" Margin="0,0,0,3" FontSize="11"/>
                    <ComboBox x:Name="templateComboBox" Style="{DynamicResource StandardComboBoxStyle}" Height="28" MaxDropDownHeight="250"/>
                </StackPanel>
                <StackPanel Grid.Row="0" Grid.Column="4" Margin="0,0,0,6">
                    <TextBlock Text="3D view type" Style="{DynamicResource LabelTextBlockStyle}" Margin="0,0,0,3" FontSize="11"/>
                    <ComboBox x:Name="viewTypeComboBox" Style="{DynamicResource StandardComboBoxStyle}" Height="28">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}" Foreground="{DynamicResource TextBrush}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>
                <StackPanel Grid.Row="0" Grid.Column="6" Margin="0,0,0,6">
                    <TextBlock Text="Sheet no. prefix" Style="{DynamicResource LabelTextBlockStyle}" Margin="0,0,0,3" FontSize="11"/>
                    <TextBox x:Name="sheetPrefixTextBox" Style="{DynamicResource PlaceholderTextBoxStyle}"
                             Tag="e.g. CV-" Height="28" Text="CV-"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,0,4">
                    <TextBlock Text="View name prefix" Style="{DynamicResource LabelTextBlockStyle}" Margin="0,0,0,3" FontSize="11"/>
                    <TextBox x:Name="namePrefixTextBox" Style="{DynamicResource PlaceholderTextBoxStyle}"
                             Tag="Prefix..." Height="28" Text="Clash - "/>
                </StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,0,4">
                    <TextBlock Text="Section box padding (mm)" Style="{DynamicResource LabelTextBlockStyle}" Margin="0,0,0,3" FontSize="11"/>
                    <TextBox x:Name="cropOffsetTextBox" Style="{DynamicResource PlaceholderTextBoxStyle}"
                             Tag="Padding..." Height="28" Text="300"/>
                </StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="4" Margin="0,0,0,4">
                    <TextBlock Text="Grid columns" Style="{DynamicResource LabelTextBlockStyle}" Margin="0,0,0,3" FontSize="11"/>
                    <TextBox x:Name="gridColumnsTextBox" Style="{DynamicResource PlaceholderTextBoxStyle}"
                             Tag="Max viewports per row" Height="28" Text="20"/>
                </StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="6" Margin="0,0,0,4">
                    <TextBlock Text="Sheet name" Style="{DynamicResource LabelTextBlockStyle}" Margin="0,0,0,3" FontSize="11"/>
                    <TextBox x:Name="sheetNameTextBox" Style="{DynamicResource PlaceholderTextBoxStyle}"
                             Tag="Sheet title..." Height="28" Text="Clash Views"/>
                </StackPanel>

                <TextBlock Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="7"
                           TextWrapping="Wrap"
                           Text="Each clashing category pair produces ONE isolated 3D view containing every element that clashes within that pair. Views are tiled on a sheet with no title block."
                           Style="{DynamicResource SecondaryTextBlockStyle}" FontSize="11" FontStyle="Italic" Margin="0,2,0,0"/>
            </Grid>
        </GroupBox>

        <!-- Categories -->
        <GroupBox Grid.Row="2" Header="Categories to clash" Margin="0,0,0,10">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0"
                           Text="Pick two or more categories. Every unordered pair (A x B) is clashed. Pairs with zero clashes are skipped."
                           Style="{DynamicResource BodyTextBlockStyle}"
                           Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,0,0,6"/>
                <TextBox Grid.Row="1" x:Name="categorySearchTextBox" Style="{DynamicResource PlaceholderTextBoxStyle}"
                         Tag="Search categories..." Height="28" Margin="0,0,0,8"
                         TextChanged="categorySearchTextBox_TextChanged"/>
                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,8">
                    <Button x:Name="categorySelectAllButton" Content="Select all" Width="88" Height="26" Margin="0,0,8,0"
                            Style="{DynamicResource StandardButtonStyle}" ToolTip="Include all categories"
                            Click="categorySelectAllButton_Click"/>
                    <Button x:Name="categoryDeselectAllButton" Content="Deselect all" Width="88" Height="26"
                            Style="{DynamicResource SecondaryButtonStyle}" ToolTip="Exclude all categories"
                            Click="categoryDeselectAllButton_Click"/>
                </StackPanel>
                <Grid Grid.Row="3">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="3">
                        <ListBox x:Name="categoryListBox" Background="{DynamicResource ControlBackgroundBrush}"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox Content="{Binding CategoryName}"
                                              IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              Checked="categoryFilterCheckBox_Changed" Unchecked="categoryFilterCheckBox_Changed"
                                              Style="{DynamicResource StandardCheckBoxStyle}" Margin="2,2"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>
                    <TextBlock Grid.Row="1" x:Name="categorySelectionCountText" Margin="0,6,0,0"
                               Style="{DynamicResource SecondaryTextBlockStyle}" Text="0 of 0 categories selected (0 pairs to clash)"/>
                </Grid>
            </Grid>
        </GroupBox>

        <!-- Status and Buttons -->
        <Border Grid.Row="3" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0"
                Background="{DynamicResource BackgroundLightBrush}" Margin="-15,10,-15,-15" Padding="15,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="statusText" Grid.Column="0" VerticalAlignment="Center"
                           Style="{DynamicResource StatusTextBlockStyle}"
                           Text="Ready to create clash views"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="createButton" Content="Create Clash Views" Width="160" Height="30" IsDefault="True"
                            Style="{DynamicResource StandardButtonStyle}" Margin="0,0,10,0"
                            Click="createButton_Click"/>
                    <Button x:Name="cancelButton" Content="Cancel" Width="100" Height="30" IsCancel="True"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Click="cancelButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
