<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Create Family Elevations" Width="1000" Height="820" MinWidth="800" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBackgroundBrush}">
    <!-- Styles will be loaded programmatically -->
    <Grid Margin="15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*" MinHeight="260"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="Create Family Elevations" Style="{DynamicResource HeaderTextBlockStyle}" Margin="0,0,0,5"/>
            <TextBlock Text="Select categories and family instances. Section views use instance bounding box and facing orientation; views are placed on sheets in a grid layout."
                       Style="{DynamicResource BodyTextBlockStyle}" 
                       Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
        </StackPanel>

        <!-- Views + sheet (compact) -->
        <GroupBox Grid.Row="1" Header="Views and sheet" Margin="0,0,0,10" Padding="0,4,0,8">
            <Grid Margin="10,4,10,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,6">
                    <TextBlock Text="View scale" Style="{DynamicResource LabelTextBlockStyle}" Margin="0,0,0,3" FontSize="11"/>
                    <ComboBox x:Name="scaleComboBox" Style="{DynamicResource StandardComboBoxStyle}" Height="28"/>
                </StackPanel>
                <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,6">
                    <TextBlock Text="View template" Style="{DynamicResource LabelTextBlockStyle}" Margin="0,0,0,3" FontSize="11"/>
                    <ComboBox x:Name="templateComboBox" Style="{DynamicResource StandardComboBoxStyle}" Height="28" MaxDropDownHeight="250"/>
                </StackPanel>
                <StackPanel Grid.Row="0" Grid.Column="4" Margin="0,0,0,6">
                    <TextBlock Text="Section type" Style="{DynamicResource LabelTextBlockStyle}" Margin="0,0,0,3" FontSize="11"/>
                    <ComboBox x:Name="elevationTypeComboBox" Style="{DynamicResource StandardComboBoxStyle}" Height="28">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}" Foreground="{DynamicResource TextBrush}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>
                <StackPanel Grid.Row="0" Grid.Column="6" Margin="0,0,0,6">
                    <TextBlock Text="Sheet no. prefix" Style="{DynamicResource LabelTextBlockStyle}" Margin="0,0,0,3" FontSize="11"/>
                    <TextBox x:Name="sheetPrefixTextBox" Style="{DynamicResource PlaceholderTextBoxStyle}" 
                             Tag="e.g. FE-" Height="28" Text="FE-"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,0,4">
                    <TextBlock Text="Name prefix" Style="{DynamicResource LabelTextBlockStyle}" Margin="0,0,0,3" FontSize="11"/>
                    <TextBox x:Name="namePrefixTextBox" Style="{DynamicResource PlaceholderTextBoxStyle}" 
                             Tag="Prefix..." Height="28" Text="Elev - "/>
                </StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,0,4">
                    <TextBlock Text="Crop offset (mm)" Style="{DynamicResource LabelTextBlockStyle}" Margin="0,0,0,3" FontSize="11"/>
                    <TextBox x:Name="cropOffsetTextBox" Style="{DynamicResource PlaceholderTextBoxStyle}" 
                             Tag="Padding..." Height="28" Text="300"/>
                </StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="4" Margin="0,0,0,4">
                    <TextBlock Text="Group by" Style="{DynamicResource LabelTextBlockStyle}" Margin="0,0,0,3" FontSize="11"/>
                    <ComboBox x:Name="groupByComboBox" Style="{DynamicResource StandardComboBoxStyle}" Height="28"/>
                </StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="6" Margin="0,0,0,4">
                    <TextBlock Text="Sort by" Style="{DynamicResource LabelTextBlockStyle}" Margin="0,0,0,3" FontSize="11"/>
                    <ComboBox x:Name="sortByComboBox" Style="{DynamicResource StandardComboBoxStyle}" Height="28"/>
                </StackPanel>

                <TextBlock Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="7"
                           TextWrapping="Wrap"
                           Text="Sections use each instance's axis-aligned bounding box plus offset. Sheet: up to 20 viewports per row, gaps between groups, no title block."
                           Style="{DynamicResource SecondaryTextBlockStyle}" FontSize="11" FontStyle="Italic" Margin="0,2,0,0"/>
            </Grid>
        </GroupBox>

        <!-- Categories + Instances: two vertical panels -->
        <GroupBox Grid.Row="2" Header="Categories and instances" Margin="0,0,0,10">
            <Grid Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*" MinWidth="160"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="3*" MinWidth="320"/>
                </Grid.ColumnDefinitions>

                <!-- Left: Categories -->
                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Categories" Style="{DynamicResource LabelTextBlockStyle}" Margin="0,0,0,6"/>
                    <TextBox Grid.Row="1" x:Name="categorySearchTextBox" Style="{DynamicResource PlaceholderTextBoxStyle}"
                             Tag="Search categories..." Height="28" Margin="0,0,0,8"
                             TextChanged="categorySearchTextBox_TextChanged"/>
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,8">
                        <Button x:Name="categorySelectAllButton" Content="Select all" Width="88" Height="26" Margin="0,0,8,0"
                                Style="{DynamicResource StandardButtonStyle}" ToolTip="Include all categories"
                                Click="categorySelectAllButton_Click"/>
                        <Button x:Name="categoryDeselectAllButton" Content="Deselect all" Width="88" Height="26"
                                Style="{DynamicResource SecondaryButtonStyle}" ToolTip="Exclude all categories"
                                Click="categoryDeselectAllButton_Click"/>
                    </StackPanel>
                    <Grid Grid.Row="3">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="3">
                            <ListBox x:Name="categoryListBox" Background="{DynamicResource ControlBackgroundBrush}"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox Content="{Binding CategoryName}" 
                                                  IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  Checked="categoryFilterCheckBox_Changed" Unchecked="categoryFilterCheckBox_Changed"
                                                  Style="{DynamicResource StandardCheckBoxStyle}" Margin="2,2"/>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>
                        <TextBlock Grid.Row="1" x:Name="categorySelectionCountText" Margin="0,6,0,0"
                                   Style="{DynamicResource SecondaryTextBlockStyle}" Text="0 of 0 categories included"/>
                    </Grid>
                </Grid>

                <!-- Right: Instances -->
                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Instances" Style="{DynamicResource LabelTextBlockStyle}" Margin="0,0,0,6"/>
                    <TextBox Grid.Row="1" x:Name="instanceSearchTextBox" Style="{DynamicResource PlaceholderTextBoxStyle}" 
                             Tag="Search by mark, category, family, type, level..." Height="28" Margin="0,0,0,8"
                             TextChanged="instanceSearchTextBox_TextChanged"/>
                    <StackPanel Grid.Row="2" Margin="0,0,0,6">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <Button x:Name="instanceSelectAllFilteredButton" Content="Select all" Width="88" Height="26" Margin="0,0,8,0"
                                    Style="{DynamicResource StandardButtonStyle}" ToolTip="Select every row in the filtered list"
                                    Click="instanceSelectAllFilteredButton_Click"/>
                            <Button x:Name="instanceDeselectAllFilteredButton" Content="Deselect all" Width="88" Height="26"
                                    Style="{DynamicResource SecondaryButtonStyle}" ToolTip="Clear all row selection"
                                    Click="instanceDeselectAllFilteredButton_Click"/>
                        </StackPanel>
                        <TextBlock Text="Tip: Ctrl+click to add rows; Shift+click for a range. Selected rows are created as elevations."
                                   Style="{DynamicResource SecondaryTextBlockStyle}" FontSize="11" TextWrapping="Wrap"/>
                    </StackPanel>
                    <Grid Grid.Row="3">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="3">
                            <DataGrid x:Name="instancesDataGrid"
                                      SelectionMode="Extended"
                                      SelectionChanged="instancesDataGrid_SelectionChanged"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      CanUserSortColumns="True"
                                      CanUserReorderColumns="False"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      GridLinesVisibility="None"
                                      HeadersVisibility="Column"
                                      BorderThickness="0"
                                      Background="{DynamicResource ControlBackgroundBrush}"
                                      RowBackground="{DynamicResource DataGridRowBackgroundBrush}"
                                      HorizontalGridLinesBrush="{DynamicResource BorderBrush}"
                                      VerticalGridLinesBrush="Transparent"
                                      RowHeight="24"
                                      FontSize="12"
                                      SelectionUnit="FullRow"
                                      CanUserResizeRows="False"
                                      AlternatingRowBackground="{DynamicResource BackgroundLightBrush}"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Auto">
                                <!-- Selection colors: use implicit styles from CommonStyles.xaml (cell-level
                                     SelectionBrush + template). Local row/cell overrides break unfocused
                                     selection when focus moves to the category list (white rows / faint text). -->
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Category" Binding="{Binding CategoryName}" Width="110"
                                                        SortMemberPath="CategoryName" CanUserSort="True"/>
                                    <DataGridTextColumn Header="Mark" Binding="{Binding Mark}" Width="72"
                                                        SortMemberPath="Mark" CanUserSort="True"/>
                                    <DataGridTextColumn Header="Family" Binding="{Binding FamilyName}" Width="120"
                                                        SortMemberPath="FamilyName" CanUserSort="True"/>
                                    <DataGridTextColumn Header="Type" Binding="{Binding TypeName}" Width="100"
                                                        SortMemberPath="TypeName" CanUserSort="True"/>
                                    <DataGridTextColumn Header="Level" Binding="{Binding LevelName}" Width="88"
                                                        SortMemberPath="LevelName" CanUserSort="True"/>
                                    <DataGridTextColumn Header="Comments" Binding="{Binding Comments}" Width="*"
                                                        SortMemberPath="Comments" CanUserSort="True"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                        <TextBlock Grid.Row="1" x:Name="selectionCountText" Margin="0,6,0,0"
                                   Style="{DynamicResource SecondaryTextBlockStyle}" Text="0 instances selected"/>
                    </Grid>
                </Grid>
            </Grid>
        </GroupBox>

        <!-- Status and Buttons -->
        <Border Grid.Row="3" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" 
                Background="{DynamicResource BackgroundLightBrush}" Margin="-15,10,-15,-15" Padding="15,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock x:Name="statusText" Grid.Column="0" VerticalAlignment="Center"
                           Style="{DynamicResource StatusTextBlockStyle}"
                           Text="Ready to create family elevations"/>
                
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="createButton" Content="Create Elevations" Width="140" Height="30" IsDefault="True" 
                            Style="{DynamicResource StandardButtonStyle}" Margin="0,0,10,0"
                            Click="createButton_Click"/>
                    <Button x:Name="cancelButton" Content="Cancel" Width="100" Height="30" IsCancel="True" 
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Click="cancelButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
